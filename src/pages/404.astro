---
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>404 | CodeceptJS Docs</title>
    <meta name="robots" content="noindex" />
    <style>
      :root {
        color-scheme: light dark;
      }

      body {
        margin: 0;
        min-height: 100vh;
        display: grid;
        place-items: center;
        text-align: center;
        font-family: var(--sl-font, ui-sans-serif, system-ui, sans-serif);
        color: var(--sl-color-text, #111827);
        background:
          radial-gradient(circle at 20% 20%, rgba(250, 204, 21, 0.12), transparent 45%),
          radial-gradient(circle at 80% 80%, rgba(59, 130, 246, 0.12), transparent 45%),
          var(--sl-color-bg, #ffffff);
      }

      main {
        padding: 2rem;
      }

      h1 {
        margin: 0 0 0.75rem;
        line-height: 1;
        font-size: clamp(3rem, 10vw, 7rem);
      }

      p {
        margin: 0 0 1rem;
        opacity: 0.9;
      }

      .links {
        display: flex;
        flex-wrap: wrap;
        justify-content: center;
        gap: 0.75rem;
      }

      a {
        color: var(--sl-color-text-accent, #2563eb);
        text-decoration: none;
      }

      a:hover {
        text-decoration: underline;
      }
    </style>
  </head>
  <body>
    <main>
      <h1>404</h1>
      <p>The page you requested was not found.</p>
      <div class="links">
        <a href="/">Home</a>
        <a href="/quickstart">Quickstart</a>
        <a href="/web-api">Web API</a>
        <a href="/mobile">Mobile Testing</a>
      </div>
    </main>
  </body>
</html>
