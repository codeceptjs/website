---
---

{/* Community Section */}
<section class="mt-0 py-24 bg-white dark:bg-gray-950 transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-bold text-gray-900 dark:text-white mb-4">
        On GitHub. On Slack. On <span class="headline-accent">your side</span>.
      </h2>
      <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
        Open-source, maintained by humans who actually answer.
      </p>
    </div>

    <div class="grid md:grid-cols-3 gap-6">
      {/* GitHub */}
      <a
          href="https://github.com/codeceptjs/CodeceptJS"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline group bg-white dark:bg-gray-900 rounded-xl p-6 border border-gray-200 dark:border-gray-800 hover:border-purple-500 dark:hover:border-purple-400 transition-colors duration-150"
      >
        <div class="flex items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900 dark:text-white"><path d="M15 22v-4a4.8 4.8 0 0 0-1-3.5c3 0 6-2 6-5.5.08-1.25-.27-2.48-1-3.5.28-1.15.28-2.35 0-3.5 0 0-1 0-3 1.5-2.64-.5-5.36-.5-8 0C6 2 5 2 5 2c-.3 1.15-.3 2.35 0 3.5A5.403 5.403 0 0 0 4 9c0 3.5 3 5.5 6 5.5-.39.49-.68 1.05-.85 1.65-.17.6-.22 1.23-.15 1.85v4"></path><path d="M9 18c-4.51 2-5-2-7-2"></path></svg>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">GitHub</h3>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Source, issues, releases. Star the repo, file a bug, send a PR.
        </p>
      </a>

      {/* Slack */}
      <a
          href="https://bit.ly/chat-codeceptjs"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline group bg-white dark:bg-gray-900 rounded-xl p-6 border border-gray-200 dark:border-gray-800 hover:border-purple-500 dark:hover:border-purple-400 transition-colors duration-150"
      >
        <div class="flex items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900 dark:text-white"><line x1="4" x2="20" y1="9" y2="9"></line><line x1="4" x2="20" y1="15" y2="15"></line><line x1="10" x2="8" y1="3" y2="21"></line><line x1="16" x2="14" y1="3" y2="21"></line></svg>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Slack</h3>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Real-time chat with maintainers and users. Stuck? Drop in.
        </p>
      </a>

      {/* Forum */}
      <a
          href="https://codecept.discourse.group"
          target="_blank"
          rel="noopener noreferrer"
          class="no-underline group bg-white dark:bg-gray-900 rounded-xl p-6 border border-gray-200 dark:border-gray-800 hover:border-purple-500 dark:hover:border-purple-400 transition-colors duration-150"
      >
        <div class="flex items-center gap-3 mb-4">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-gray-900 dark:text-white"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
          <h3 class="text-lg font-semibold text-gray-900 dark:text-white">Forum</h3>
        </div>
        <p class="text-sm text-gray-500 dark:text-gray-400">
          Long-form discussions, recipes, and the occasional war story.
        </p>
      </a>
    </div>

    <p class="text-center text-sm text-gray-400 dark:text-gray-500 mt-10">
      Also on <a href="https://twitter.com/codeceptjs" class="hover:text-purple-500 transition-colors">Twitter</a>,
      <a href="https://stackoverflow.com/questions/tagged/codeceptjs" class="hover:text-purple-500 transition-colors">Stack Overflow</a>,
      and <a href="https://github.com/codeceptjs/CodeceptJS/discussions" class="hover:text-purple-500 transition-colors">GitHub Discussions</a>.
    </p>
  </div>
</section>
