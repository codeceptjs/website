---
---

<section id="quotes" class="!mt-0 py-16 transition-colors duration-300">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
        <h2 class="text-3xl md:text-4xl font-bold text-center mb-12 text-gray-900 dark:text-white tracking-tight">
            What teams say.
        </h2>

        <div class="grid md:grid-cols-2 gap-6">
            <figure class="bg-white dark:bg-gray-900 rounded-xl p-7 border border-gray-200 dark:border-gray-800 flex flex-col h-full m-0">
                <blockquote class="text-lg leading-relaxed text-gray-800 dark:text-gray-200 mb-5 m-0 italic flex-1">
                    &ldquo;Test an application like Percona Monitoring and Management with so many dashboards &amp; metric plots.&rdquo;
                </blockquote>
                <figcaption class="flex items-center gap-3 mt-auto">
                    <img src="/img/kala.jpg" alt="" width="40" height="40" class="w-10 h-10 rounded-full object-cover flex-shrink-0 m-0" />
                    <div class="text-sm leading-tight">
                        <div class="font-semibold text-gray-900 dark:text-white">Puneet Kala</div>
                        <div class="text-gray-500 dark:text-gray-400 mt-0.5">Frontend QA Automation Engineer · Percona</div>
                    </div>
                </figcaption>
            </figure>

            <figure class="bg-white dark:bg-gray-900 rounded-xl p-7 border border-gray-200 dark:border-gray-800 flex flex-col h-full m-0">
                <blockquote class="text-lg leading-relaxed text-gray-800 dark:text-gray-200 mb-5 m-0 italic flex-1">
                    &ldquo;CodeceptJS helps us write tests which are good to read and easy to write, run on several browsers.&rdquo;
                </blockquote>
                <figcaption class="flex items-center gap-3 mt-auto">
                    <img src="/img/mitko.jpg" alt="" width="40" height="40" class="w-10 h-10 rounded-full object-cover flex-shrink-0 m-0" />
                    <div class="text-sm leading-tight">
                        <div class="font-semibold text-gray-900 dark:text-white">Mitko Tschimev</div>
                        <div class="text-gray-500 dark:text-gray-400 mt-0.5">Frontend Tech Lead · My Porsche Core</div>
                    </div>
                </figcaption>
            </figure>
        </div>
    </div>
</section>
