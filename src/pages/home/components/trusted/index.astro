---
import { Image } from "astro:assets";
import BC_LogoScreen_C from "./images/_BC_LogoScreen_C.jpg";
import doxyme from "./images/_doxyme.png";
import gen3 from "./images/_gen3.png";
import isotipo from "./images/_isotipo.png";
import kiabi from "./images/_kiabi.png";
import mynd from "./images/_mynd.png";
import zenitech from "./images/_zenitech.png";

import "swiper/css";
import "swiper/css/pagination";
---

<section id="trusted" class="!mt-0 py-16 relative overflow-hidden transition-colors duration-300">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <p class="text-center text-sm text-gray-400 dark:text-gray-500 uppercase tracking-wider mb-10 font-medium">
      Trusted by industry leaders
    </p>

    {/* Logo Slider */}
    <div class="swiper swiper-trusted">
      <div class="swiper-wrapper">
        {
          [
            { image: BC_LogoScreen_C, alt: "BC logo" },
            { image: doxyme, alt: "Doxy.me logo" },
            { image: gen3, alt: "Gen3 logo" },
            { image: isotipo, alt: "Isotipo logo" },
            { image: kiabi, alt: "Kiabi logo" },
            { image: mynd, alt: "Mynd logo" },
            { image: zenitech, alt: "Zenitech logo" },
          ].map((item) =>
              <div class="swiper-slide group flex flex-col items-center justify-center p-6">
                <Image class="text-4xl mb-2 group-hover:scale-110 transition-transform duration-300 grayscale opacity-60 group-hover:grayscale-0 group-hover:opacity-100" src={item.image} alt={item.alt} />
              </div>
          )
        }
      </div>
      <div class="swiper-pagination"></div>
    </div>
  </div>
</section>

<script>
  import Swiper from "swiper";
  import { Pagination, Autoplay } from "swiper/modules";

  document.addEventListener("astro:page-load", () => {
    const swiper = new Swiper(".swiper-trusted", {
      modules: [Pagination, Autoplay],
      slidesPerView: 5,
      spaceBetween: 30,
      loop: true,
      grabCursor: true,
      pagination: {
        el: ".swiper-pagination",
        clickable: true
      },
      autoplay: {
        delay: 10000
      }
    });
  });

</script>
