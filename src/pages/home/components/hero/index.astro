---

---

{/* Hero Section */}
<section class="hero-section !mt-0 -mt-22 relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-24">

    {/* Animated background — wallpaper of CodeceptJS commands drifting diagonally */}
    <svg class="hero-wallpaper" aria-hidden="true" xmlns="http://www.w3.org/2000/svg">
        <defs>
            <pattern id="cmd-tile" patternUnits="userSpaceOnUse" width="900" height="640" patternTransform="rotate(-9)">
                {/* Layer A — medium snippets */}
                <text x="20"  y="40"  class="ww ww-md">I.click('Add to Cart')</text>
                <text x="360" y="78"  class="ww ww-sm ww-faint">I.see('$29.99', '.price')</text>
                <text x="600" y="46"  class="ww ww-md">I.amOnPage('/dashboard')</text>
                <text x="40"  y="118" class="ww ww-lg">I.fillField('Email', 'jane@codecept.io')</text>
                <text x="540" y="146" class="ww ww-sm ww-faint">{`I.click({ xpath: '//button[@aria-label="Close"]' })`}</text>
                <text x="80"  y="200" class="ww ww-sm">I.pressKey(['Cmd','K'])</text>
                <text x="320" y="220" class="ww ww-md">I.see('Order confirmed', '.checkout')</text>
                <text x="700" y="200" class="ww ww-sm ww-faint">I.dontSee('Error')</text>
                <text x="20"  y="280" class="ww ww-sm ww-faint">{`I.click({ role: 'button', name: 'Save changes' })`}</text>
                <text x="430" y="296" class="ww ww-md">I.waitForText('Welcome back', 5)</text>
                <text x="60"  y="358" class="ww ww-md">I.click('Sign In')</text>
                <text x="280" y="378" class="ww ww-sm">I.dontSeeInCurrentUrl('/login')</text>
                <text x="600" y="362" class="ww ww-sm ww-faint">{`I.fillField('//input[@name="q"]', 'codeceptjs')`}</text>
                <text x="20"  y="438" class="ww ww-lg">{`I.click({ css: '[data-testid="checkout-submit"]' })`}</text>
                <text x="540" y="446" class="ww ww-sm">I.scrollTo('.footer')</text>
                <text x="100" y="510" class="ww ww-md">I.see('1 item left', '.todos')</text>
                <text x="450" y="520" class="ww ww-sm ww-faint">I.attachFile('#avatar', 'photo.jpg')</text>
                <text x="700" y="510" class="ww ww-sm">I.refreshPage()</text>
                <text x="40"  y="586" class="ww ww-md">I.fillField('Card number', '4242 4242 4242 4242')</text>
                <text x="540" y="600" class="ww ww-sm ww-faint">I.waitForElement('.dashboard', 10)</text>
            </pattern>
        </defs>
        <rect class="hero-wallpaper-rect" width="100%" height="100%" fill="url(#cmd-tile)"></rect>
    </svg>

    {/* Periodic test-pass checkmarks flashing in the background */}
    <div class="hero-passes" aria-hidden="true">
        <span class="hero-tick" style="left:8%;top:14%;animation-delay:0.4s">✓</span>
        <span class="hero-tick" style="left:78%;top:22%;animation-delay:1.6s">✓</span>
        <span class="hero-tick" style="left:18%;top:62%;animation-delay:2.8s">✓</span>
        <span class="hero-tick" style="left:88%;top:68%;animation-delay:3.4s">✓</span>
        <span class="hero-tick" style="left:42%;top:8%;animation-delay:4.6s">✓</span>
        <span class="hero-tick" style="left:62%;top:84%;animation-delay:5.8s">✓</span>
        <span class="hero-tick" style="left:5%;top:38%;animation-delay:7.0s">✓</span>
        <span class="hero-tick" style="left:92%;top:46%;animation-delay:8.2s">✓</span>
    </div>

    {/* Soft vignette so content reads */}
    <div class="hero-vignette" aria-hidden="true"></div>

    {/* Content */}
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 w-full">
        <div class="grid md:grid-cols-12 gap-10 md:gap-10 lg:gap-12 items-center">

            {/* LEFT — Headline & CTAs */}
            <div class="md:col-span-5 hero-stagger">
                <div class="hero-eyebrow font-bold text-base sm:text-lg tracking-tight mb-1">
                    CodeceptJS
                </div>

                <h1 class="hero-headline text-5xl sm:text-6xl lg:text-[5rem] font-bold leading-[1.02] tracking-tight mb-6 text-gray-900 dark:text-white">
                    <span class="block">End-to-end</span>
                    <span class="block">testing,</span>
                    <span class="block">written like</span>
                    <span class="hero-highlight">prose</span><span>.</span>
                </h1>

                <p class="text-lg text-gray-500 dark:text-gray-400 max-w-md leading-relaxed mb-8">
                    Write less. Test more.<br />
                    Works with Playwright, WebDriver, Puppeteer, and Appium.
                </p>

                <div class="flex flex-row gap-3 mb-6">
                    <a href="/quickstart" class="hero-cta-primary mt-0 no-underline px-6 py-3 rounded-lg font-semibold text-white bg-purple-600 hover:bg-purple-700 dark:bg-purple-500 dark:hover:bg-purple-400 transition-colors duration-150 cursor-pointer inline-flex items-center gap-2">
                        Start Now
                        <span class="hero-cta-arrow">&rarr;</span>
                    </a>
                    <a href="/quickstart" class="mt-0 no-underline px-6 py-3 rounded-lg font-semibold border border-gray-300 dark:border-gray-700 text-gray-900 dark:text-white hover:border-purple-500 dark:hover:border-purple-400 transition-colors duration-150 cursor-pointer">
                        Read Docs
                    </a>
                </div>

                <div class="flex items-center gap-4 text-xs text-gray-400 dark:text-gray-500 font-mono">
                    <span class="flex items-center gap-1.5">
                        <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 hero-pulse"></span>
                        v3.7
                    </span>
                    <span>·</span>
                    <span>MIT</span>
                    <span>·</span>
                    <span>Node 18+</span>
                </div>
            </div>

            {/* RIGHT — Scenario panel + live runner */}
            <div class="md:col-span-7 hero-stagger hero-stagger-2">
                <div class="hero-panel-wrap">
                    <div class="hero-panel">
                        {/* Window chrome */}
                        <div class="hero-panel-bar">
                            <span class="hero-dot hero-dot-r"></span>
                            <span class="hero-dot hero-dot-y"></span>
                            <span class="hero-dot hero-dot-g"></span>
                            <span class="hero-panel-title">tests/todo_test.js</span>
                            <span class="hero-panel-status" id="hero-runner-status">
                                <span class="hero-runner-dot"></span>
                                <span id="hero-runner-text">running…</span>
                            </span>
                        </div>

                        {/* Code area */}
                        <div class="hero-panel-body">
                            <div class="hero-code-col">
                                <pre id="hero-code" class="hero-code" aria-label="CodeceptJS scenario"></pre>
                            </div>

                            {/* Live runner sidebar */}
                            <aside class="hero-runner" aria-hidden="true">
                                <div class="hero-runner-head">
                                    <span class="hero-runner-label">RUN</span>
                                    <span id="hero-runner-time" class="hero-runner-time">0.0s</span>
                                </div>
                                <ul id="hero-runner-list" class="hero-runner-list"></ul>
                                <div id="hero-runner-summary" class="hero-runner-summary"></div>
                            </aside>
                        </div>
                    </div>
                </div>

                {/* Quiet install row */}
                <div class="hero-install mt-6" id="install-widget">
                    <div id="install-tabs"></div>
                    <div id="install-body"></div>
                </div>
            </div>
        </div>
    </div>

    <style is:global>
        @import url('https://fonts.googleapis.com/css2?family=Instrument+Serif:ital@0;1&family=JetBrains+Mono:wght@400;500;700&display=swap');

        .hero-section {
            isolation: isolate;

            /* Panel theme — light mode (matches Example IDE panel) */
            --hp-bg: #ffffff;
            --hp-bar-bg: #f9fafb;
            --hp-runner-bg: #f9fafb;
            --hp-border: rgba(0, 0, 0, 0.08);
            --hp-divider: rgba(0, 0, 0, 0.06);
            --hp-text: #1f2937;
            --hp-text-mute: #6b7280;
            --hp-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.12);

            --hc-key: #7c3aed;
            --hc-str: #0369a1;
            --hc-I:   #db2777;
            --hc-txt: #1f2937;
            --hc-caret: #4b5563;
        }
        html[data-theme="dark"] .hero-section {
            --hp-bg: #14161e;
            --hp-bar-bg: #1f2230;
            --hp-runner-bg: #14161e;
            --hp-border: rgba(255, 255, 255, 0.08);
            --hp-divider: rgba(255, 255, 255, 0.06);
            --hp-text: #c9d1d9;
            --hp-text-mute: #8b949e;
            --hp-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);

            --hc-key: #c084fc;
            --hc-str: #7dd3fc;
            --hc-I:   #f472b6;
            --hc-txt: #c9d1d9;
            --hc-caret: #c9d1d9;
        }

        /* Wallpaper */
        .hero-wallpaper {
            position: absolute;
            inset: -10% -10%;
            width: 120%;
            height: 120%;
            z-index: 0;
            pointer-events: none;
            animation: hero-drift 90s linear infinite;
        }
        .ww {
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            font-weight: 500;
            user-select: none;
            fill: rgba(31, 41, 55, 0.085);
        }
        .ww-sm { font-size: 14px; }
        .ww-md { font-size: 18px; }
        .ww-lg { font-size: 22px; font-weight: 600; }
        .ww-faint { fill: rgba(31, 41, 55, 0.05); }
        html[data-theme="dark"] .ww       { fill: rgba(192, 132, 252, 0.085); }
        html[data-theme="dark"] .ww-faint { fill: rgba(192, 132, 252, 0.05); }

        @keyframes hero-drift {
            from { transform: translate(0, 0); }
            to   { transform: translate(-900px, -640px); }
        }

        /* Periodic ✓ flashes */
        .hero-passes {
            position: absolute;
            inset: 0;
            z-index: 1;
            pointer-events: none;
        }
        .hero-tick {
            position: absolute;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            font-weight: 700;
            font-size: 22px;
            color: #10b981;
            opacity: 0;
            transform: scale(0.6);
            animation: hero-tick-flash 9s ease-in-out infinite;
            text-shadow: 0 0 12px rgba(16, 185, 129, 0.4);
        }
        html[data-theme="dark"] .hero-tick { color: #34d399; }
        @keyframes hero-tick-flash {
            0%, 100% { opacity: 0; transform: scale(0.6); }
            5%       { opacity: 0.95; transform: scale(1.15); }
            12%      { opacity: 0.8; transform: scale(1); }
            22%      { opacity: 0; transform: scale(1); }
        }

        /* Vignette */
        .hero-vignette {
            position: absolute;
            inset: 0;
            z-index: 2;
            pointer-events: none;
            background:
                radial-gradient(ellipse at 50% 40%, transparent 0%, transparent 30%, rgba(255, 255, 255, 0.6) 90%);
        }
        html[data-theme="dark"] .hero-vignette {
            background:
                radial-gradient(ellipse at 50% 40%, transparent 0%, transparent 30%, rgba(26, 29, 40, 0.85) 90%);
        }

        /* Content layer above background */
        .hero-section > .relative { z-index: 3; }

        /* Headline */
        .hero-headline {
            letter-spacing: -0.02em;
            margin-top: -0.12em;
        }
        .hero-eyebrow {
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            text-transform: uppercase;
            letter-spacing: 0.18em;
            font-size: 13px !important;
            font-weight: 700;
            color: var(--codecept-accent);
        }
        .hero-highlight {
            font-family: 'Instrument Serif', Georgia, serif;
            font-style: italic;
            font-weight: 400;
            letter-spacing: -0.01em;
            position: relative;
            display: inline-block;
            padding-right: 0.05em;
            color: inherit;
            background: linear-gradient(180deg, transparent 76%, var(--codecept-accent-soft) 76%, var(--codecept-accent-soft) 92%, transparent 92%);
            background-size: 0% 100%;
            background-repeat: no-repeat;
            animation: hero-highlight-draw 1.1s 1.1s ease-out forwards;
        }
        @keyframes hero-highlight-draw {
            from { background-size: 0% 100%; }
            to   { background-size: 100% 100%; }
        }

        /* Stagger reveal on load */
        .hero-stagger > * {
            opacity: 0;
            transform: translateY(8px);
            animation: hero-rise 0.6s ease-out forwards;
        }
        .hero-stagger > *:nth-child(1) { animation-delay: 0.05s; }
        .hero-stagger > *:nth-child(2) { animation-delay: 0.18s; }
        .hero-stagger > *:nth-child(3) { animation-delay: 0.32s; }
        .hero-stagger > *:nth-child(4) { animation-delay: 0.46s; }
        .hero-stagger > *:nth-child(5) { animation-delay: 0.6s; }
        .hero-stagger-2 > * { animation-delay: 0.5s; }
        @keyframes hero-rise {
            to { opacity: 1; transform: none; }
        }

        .hero-cta-arrow { transition: transform 0.2s ease-out; display: inline-block; }
        .hero-cta-primary:hover .hero-cta-arrow { transform: translateX(3px); }

        .hero-pulse {
            box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.6);
            animation: hero-pulse-anim 2s ease-out infinite;
        }
        @keyframes hero-pulse-anim {
            0%   { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0.55); }
            70%  { box-shadow: 0 0 0 6px rgba(16, 185, 129, 0); }
            100% { box-shadow: 0 0 0 0 rgba(16, 185, 129, 0); }
        }

        /* Panel */
        .hero-panel-wrap {
            position: relative;
        }
        .hero-panel pre,
        .hero-panel aside,
        .hero-panel ul,
        .hero-panel li {
            border: 0 !important;
            outline: 0 !important;
            box-shadow: none;
        }
        .hero-panel {
            position: relative;
            border-radius: 14px;
            background: var(--hp-bg);
            border: 1px solid var(--hp-border);
            overflow: hidden;
            box-shadow: var(--hp-shadow);
        }
        .hero-panel-bar {
            display: flex;
            align-items: center;
            gap: 8px;
            padding: 12px 16px;
            background: var(--hp-bar-bg);
            border-bottom: 1px solid var(--hp-divider);
        }
        .hero-dot { width: 11px; height: 11px; border-radius: 50%; display: inline-block; }
        .hero-dot-r { background: #ff5f57; }
        .hero-dot-y { background: #febc2e; }
        .hero-dot-g { background: #28c840; }
        .hero-panel-title {
            margin-left: 12px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            font-size: 12px;
            color: var(--hp-text-mute);
            letter-spacing: 0.02em;
        }
        .hero-panel-status {
            margin-left: auto;
            display: inline-flex;
            align-items: center;
            gap: 6px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            font-size: 11px;
            color: var(--hp-text-mute);
            text-transform: uppercase;
            letter-spacing: 0.08em;
        }
        .hero-runner-dot {
            width: 6px; height: 6px; border-radius: 50%;
            background: #fbbf24;
            box-shadow: 0 0 8px rgba(251, 191, 36, 0.7);
            animation: hero-runner-spin 1s ease-in-out infinite;
        }
        .hero-runner-dot.done {
            background: #10b981;
            box-shadow: 0 0 8px rgba(16, 185, 129, 0.5);
            animation: none;
        }
        @keyframes hero-runner-spin {
            0%, 100% { opacity: 0.4; transform: scale(0.85); }
            50%      { opacity: 1; transform: scale(1.15); }
        }

        .hero-panel-body {
            display: grid;
            grid-template-columns: 1fr 220px;
        }
        @media (max-width: 768px) {
            .hero-panel-body { grid-template-columns: 1fr; }
            .hero-runner { border-top: 1px solid rgba(255, 255, 255, 0.06); border-left: none !important; }
        }
        .hero-code-col {
            padding: 20px 22px 22px;
            min-height: 230px;
        }
        .hero-code {
            margin: 0;
            padding: 0;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
            font-size: 14.5px;
            line-height: 1.85;
            color: var(--hp-text);
            white-space: pre;
            background: transparent;
        }

        .hero-runner {
            border-left: 1px solid var(--hp-divider) !important;
            background: var(--hp-runner-bg);
            padding: 16px 16px 18px;
            font-family: 'JetBrains Mono', ui-monospace, monospace;
        }
        .hero-runner-head {
            display: flex;
            justify-content: space-between;
            align-items: baseline;
            margin-bottom: 12px;
        }
        .hero-runner-label {
            font-size: 10px;
            font-weight: 700;
            color: var(--hp-text-mute);
            letter-spacing: 0.18em;
        }
        .hero-runner-time {
            font-size: 11px;
            color: var(--hp-text-mute);
        }
        .hero-runner-list {
            list-style: none;
            margin: 0; padding: 0;
            display: flex;
            flex-direction: column;
            gap: 5px;
        }
        .hero-runner-list li {
            display: flex;
            align-items: center;
            gap: 8px;
            font-size: 12px;
            color: var(--hp-text);
            opacity: 0;
            transform: translateX(-4px);
            transition: opacity 0.18s ease-out, transform 0.18s ease-out;
        }
        .hero-runner-list li.show { opacity: 1; transform: none; }
        .hero-runner-list li .check {
            color: #10b981;
            font-weight: 700;
            width: 12px;
        }
        .hero-runner-list li .step {
            color: var(--hp-text-mute);
            flex: 1;
            overflow: hidden;
            text-overflow: ellipsis;
            white-space: nowrap;
        }
        .hero-runner-list li .ms {
            color: var(--hp-text-mute);
            opacity: 0.7;
            font-size: 10px;
        }
        .hero-runner-summary {
            margin-top: 14px;
            padding-top: 12px;
            border-top: 1px dashed var(--hp-divider) !important;
            font-size: 11px;
            color: #10b981;
            opacity: 0;
            transition: opacity 0.3s;
        }
        .hero-runner-summary.show { opacity: 1; }

        /* Reduced motion */
        @media (prefers-reduced-motion: reduce) {
            .hero-wallpaper, .hero-tick, .hero-stagger > *, .hero-pulse, .hero-runner-dot {
                animation: none !important;
            }
            .hero-stagger > * { opacity: 1; transform: none; }
            .hero-highlight { background-size: 100% 100%; animation: none; }
        }
    </style>
</section>

<script>
    document.addEventListener('astro:page-load', () => {
        // ---- Live-typing Scenario ----
        const codeEl = document.getElementById('hero-code');
        const runnerList = document.getElementById('hero-runner-list');
        const runnerTime = document.getElementById('hero-runner-time');
        const runnerStatus = document.getElementById('hero-runner-text');
        const runnerSummary = document.getElementById('hero-runner-summary');
        const statusDot = document.querySelector('.hero-runner-dot');

        if (codeEl && !codeEl.dataset.init) {
            codeEl.dataset.init = '1';

            const C = {
                key: 'var(--hc-key)',
                str: 'var(--hc-str)',
                I:   'var(--hc-I)',
                txt: 'var(--hc-txt)',
            };

            type Tok = { t: string; c: string };
            const lines: Tok[][] = [
                [
                    { t: 'Scenario', c: C.key },
                    { t: '(', c: C.txt },
                    { t: "'create and close a todo'", c: C.str },
                    { t: ', ({ ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: ' }) => {', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.amOnPage(', c: C.txt },
                    { t: "'/todos'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.fillField(', c: C.txt },
                    { t: "'What needs doing?'", c: C.str },
                    { t: ', ', c: C.txt },
                    { t: "'Buy milk'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.pressKey(', c: C.txt },
                    { t: "'Enter'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.see(', c: C.txt },
                    { t: "'Buy Milk'", c: C.str },
                    { t: ', ', c: C.txt },
                    { t: "'.todos'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.click(', c: C.txt },
                    { t: "'.todos .toggle'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '  ', c: C.txt },
                    { t: 'I', c: C.I },
                    { t: '.see(', c: C.txt },
                    { t: "'Buy Milk'", c: C.str },
                    { t: ', ', c: C.txt },
                    { t: "'.todo.completed'", c: C.str },
                    { t: ');', c: C.txt },
                ],
                [
                    { t: '});', c: C.txt },
                ],
            ];

            // Map of code-line index -> runner step descriptor
            const runnerSteps = [
                null,
                { label: "amOnPage '/todos'", ms: 18 },
                { label: "fillField 'What…'", ms: 165 },
                { label: "pressKey 'Enter'", ms: 92 },
                { label: "see 'Buy Milk' .todos", ms: 84 },
                { label: "click .todos .toggle", ms: 210 },
                { label: "see .todo.completed", ms: 96 },
                null,
            ];

            const lineEls: HTMLElement[] = [];
            lines.forEach(() => {
                const ln = document.createElement('div');
                ln.style.minHeight = '1.85em';
                codeEl.appendChild(ln);
                lineEls.push(ln);
            });

            const caret = document.createElement('span');
            caret.textContent = '▍';
            caret.style.cssText = `display:inline-block; color:var(--hc-caret); animation: hero-blink 1s steps(2, start) infinite; margin-left:1px;`;
            codeEl.appendChild(caret);

            const styleEl = document.createElement('style');
            styleEl.textContent = `@keyframes hero-blink { to { visibility: hidden; } }`;
            document.head.appendChild(styleEl);

            const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

            function addRunnerStep(idx: number) {
                if (!runnerList) return;
                const step = runnerSteps[idx];
                if (!step) return;
                const li = document.createElement('li');
                li.innerHTML = `<span class="check">✓</span><span class="step">${step.label}</span><span class="ms">${step.ms}ms</span>`;
                runnerList.appendChild(li);
                requestAnimationFrame(() => li.classList.add('show'));
            }

            function finishRunner(totalMs: number) {
                if (statusDot) statusDot.classList.add('done');
                if (runnerStatus) runnerStatus.textContent = 'passed';
                if (runnerSummary) {
                    runnerSummary.textContent = `1 passing · ${(totalMs / 1000).toFixed(1)}s`;
                    runnerSummary.classList.add('show');
                }
            }

            if (prefersReducedMotion) {
                lines.forEach((tokens, i) => {
                    tokens.forEach(tok => {
                        const span = document.createElement('span');
                        span.textContent = tok.t;
                        span.style.color = tok.c;
                        lineEls[i].appendChild(span);
                    });
                    if (runnerSteps[i]) addRunnerStep(i);
                });
                caret.remove();
                if (runnerTime) runnerTime.textContent = '0.7s';
                finishRunner(742);
                return;
            }

            // Type character-by-character
            let lineIdx = 0;
            let tokIdx = 0;
            let charIdx = 0;
            let currentSpan: HTMLElement | null = null;
            let elapsed = 0;
            const startedAt = performance.now();

            const updateClock = () => {
                if (!runnerTime) return;
                elapsed = (performance.now() - startedAt) / 1000;
                runnerTime.textContent = elapsed.toFixed(1) + 's';
            };
            const clockTimer = setInterval(updateClock, 60);

            const typeNext = () => {
                if (lineIdx >= lines.length) {
                    setTimeout(() => caret.remove(), 1500);
                    clearInterval(clockTimer);
                    finishRunner(elapsed * 1000 + 200);
                    return;
                }
                const line = lines[lineIdx];
                if (tokIdx >= line.length) {
                    addRunnerStep(lineIdx);
                    lineIdx++;
                    tokIdx = 0;
                    charIdx = 0;
                    currentSpan = null;
                    setTimeout(typeNext, 110);
                    return;
                }
                const tok = line[tokIdx];
                if (!currentSpan) {
                    currentSpan = document.createElement('span');
                    currentSpan.style.color = tok.c;
                    lineEls[lineIdx].appendChild(currentSpan);
                }
                currentSpan.textContent = tok.t.slice(0, charIdx + 1);
                charIdx++;
                if (charIdx >= tok.t.length) {
                    tokIdx++;
                    charIdx = 0;
                    currentSpan = null;
                }
                const baseDelay = 12;
                setTimeout(typeNext, baseDelay + Math.random() * 14);
            };

            setTimeout(typeNext, 700);
        }

        // ---- Quiet install row ----
        const widget = document.getElementById('install-widget');
        if (!widget || widget.dataset.init) return;
        widget.dataset.init = '1';

        const pms = ['npm', 'yarn', 'pnpm', 'bun', 'deno'];
        const commands: Record<string, string> = {
            npm: 'npm i codeceptjs',
            yarn: 'yarn add codeceptjs',
            pnpm: 'pnpm add codeceptjs',
            bun: 'bun add codeceptjs',
            deno: 'deno add npm:codeceptjs',
        };

        widget.style.cssText = 'border-radius:8px; overflow:hidden; border:1px solid rgba(127,127,127,0.22); background:transparent; max-width:420px;';

        const tabsRow = document.getElementById('install-tabs')!;
        tabsRow.style.cssText = 'display:flex; border-bottom:1px solid rgba(127,127,127,0.16); margin:0; padding:0;';

        const tabEls: HTMLElement[] = [];
        pms.forEach(pm => {
            const btn = document.createElement('span');
            btn.textContent = pm;
            btn.dataset.pm = pm;
            btn.style.cssText = `flex:1; display:inline-flex; align-items:center; justify-content:center; padding:6px 8px; margin:0; font-size:10px; font-weight:600; color:#9ca3af; background:transparent; border:none; border-bottom:2px solid transparent; cursor:pointer; transition:color 0.15s, border-color 0.15s; user-select:none; line-height:1; letter-spacing:0.1em; text-transform:uppercase; font-family:'JetBrains Mono', ui-monospace, monospace;`;
            tabEls.push(btn);
            tabsRow.appendChild(btn);
        });

        function setActive(pm: string) {
            tabEls.forEach(el => {
                const isActive = el.dataset.pm === pm;
                el.style.color = isActive ? 'var(--sl-color-text)' : '#9ca3af';
                el.style.borderBottomColor = isActive ? '#7c3aed' : 'transparent';
            });
            cmdEl.textContent = commands[pm];
        }

        tabEls.forEach(el => {
            el.addEventListener('click', (e) => {
                e.preventDefault();
                e.stopPropagation();
                setActive(el.dataset.pm || 'npm');
            });
        });

        const body = document.getElementById('install-body')!;
        body.style.cssText = 'display:flex; align-items:center; padding:10px 12px; gap:10px; margin:0;';

        const prompt = document.createElement('span');
        prompt.textContent = '$';
        prompt.style.cssText = "color:#7c3aed; font-size:13px; user-select:none; flex-shrink:0; font-weight:700; line-height:1; margin:0; font-family:'JetBrains Mono', ui-monospace, monospace;";
        body.appendChild(prompt);

        const cmdEl = document.createElement('code');
        cmdEl.textContent = commands.npm;
        cmdEl.style.cssText = `font-size:13px; font-family:'JetBrains Mono', ui-monospace, monospace; color:var(--sl-color-text); white-space:nowrap; flex:1; background:none; line-height:1; margin:0; padding:0; text-align:left;`;
        body.appendChild(cmdEl);

        const copyBtn = document.createElement('span');
        copyBtn.title = 'Copy to clipboard';
        copyBtn.style.cssText = 'flex-shrink:0; width:22px; height:22px; display:inline-flex; align-items:center; justify-content:center; border-radius:5px; cursor:pointer; color:#9ca3af; transition:all 0.15s; margin:0; padding:0;';
        const copySvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect width="14" height="14" x="8" y="8" rx="2" ry="2"></rect><path d="M4 16c-1.1 0-2-.9-2-2V4c0-1.1.9-2 2-2h10c1.1 0 2 .9 2 2"></path></svg>`;
        const checkSvg = `<svg xmlns="http://www.w3.org/2000/svg" width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="#22c55e" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"></polyline></svg>`;
        copyBtn.innerHTML = copySvg;

        copyBtn.addEventListener('click', async (e) => {
            e.preventDefault();
            e.stopPropagation();
            await navigator.clipboard.writeText(cmdEl.textContent || '');
            copyBtn.innerHTML = checkSvg;
            setTimeout(() => { copyBtn.innerHTML = copySvg; }, 2000);
        });

        body.appendChild(copyBtn);

        setActive('npm');
    });
</script>
