---

---

{/* AI-Powered Testing Section */}
<section class="mt-0 py-24 bg-gray-50 dark:bg-gray-950 relative">
    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        {/* Section Header */}
        <div class="text-center mb-24">
            <h2 class="mt-0 text-4xl md:text-6xl font-bold leading-tight text-gray-900 dark:text-white">
                Tests that <span class="headline-accent">fix themselves</span>.
            </h2>
            <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto mt-6">
                Selectors break. UIs change. CodeceptJS heals the test before you notice.
            </p>
        </div>

        {/* Feature Panel 1: Self-Healing Tests (text left, visual right) */}
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-32">
            <div class="space-y-6">
                <h3 class="text-3xl font-bold text-gray-900 dark:text-white">Selectors that heal</h3>
                <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
                    Your designer renames a button. Your test still passes. CodeceptJS finds the new selector, swaps it in, and tells you what it changed.
                </p>
                <a href="/ai" class="explore-link no-underline inline-flex items-center gap-2 text-orange-500 dark:text-orange-400 font-semibold hover:text-orange-600 dark:hover:text-orange-300 transition-colors">
                    Explore self-healing <span class="arrow">&rarr;</span>
                </a>
            </div>
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-8 relative overflow-hidden">
                <div class="relative space-y-4">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-purple-500/10 dark:bg-purple-500/20 rounded-xl flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-purple-600 dark:text-purple-400"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"></path></svg>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 dark:text-white">Auto-Healed Selectors</span>
                    </div>
                    <div class="space-y-3">
                        <div class="flex items-center gap-3 p-3 bg-red-50/80 dark:bg-red-900/20 rounded-lg border border-red-200/50 dark:border-red-800/30">
                            <span class="text-red-500 text-xs font-mono">&#10005;</span>
                            <code class="text-sm text-red-600 dark:text-red-400 line-through">#old-submit-btn</code>
                        </div>
                        <div class="flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500"><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg>
                        </div>
                        <div class="flex items-center gap-3 p-3 bg-green-50/80 dark:bg-green-900/20 rounded-lg border border-green-200/50 dark:border-green-800/30">
                            <span class="text-green-500 text-xs font-mono">&#10003;</span>
                            <code class="text-sm text-green-600 dark:text-green-400">[data-testid="submit"]</code>
                        </div>
                    </div>
                    <p class="text-xs text-gray-400 dark:text-gray-500 mt-4">Healed automatically in 0.3s</p>
                </div>
            </div>
        </div>

        {/* Feature Panel 2: AI Visual Testing (visual left, text right) */}
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-32">
            <div class="order-2 lg:order-1 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-8 relative overflow-hidden">
                <div class="relative space-y-4">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-purple-500/10 dark:bg-purple-500/20 rounded-xl flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-purple-600 dark:text-purple-400"><path d="M2 12s3-7 10-7 10 7 10 7-3 7-10 7-10-7-10-7Z"></path><circle cx="12" cy="12" r="3"></circle></svg>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 dark:text-white">Visual Comparison</span>
                    </div>
                    <div class="grid grid-cols-2 gap-4">
                        <div class="space-y-2">
                            <div class="text-xs text-gray-400 uppercase tracking-wider">Baseline</div>
                            <div class="h-24 bg-gray-100 dark:bg-gray-700 rounded-lg border border-gray-200/50 dark:border-gray-600/50 flex items-center justify-center">
                                <div class="w-16 h-4 bg-purple-200 dark:bg-purple-700 rounded"></div>
                            </div>
                        </div>
                        <div class="space-y-2">
                            <div class="text-xs text-gray-400 uppercase tracking-wider">Current</div>
                            <div class="h-24 bg-gray-100 dark:bg-gray-700 rounded-lg border border-orange-300/50 dark:border-orange-500/30 flex items-center justify-center relative">
                                <div class="w-16 h-4 bg-orange-200 dark:bg-orange-700 rounded"></div>
                                <div class="absolute top-1 right-1 w-3 h-3 bg-orange-500 rounded-full animate-pulse"></div>
                            </div>
                        </div>
                    </div>
                    <div class="flex items-center gap-2 mt-2">
                        <div class="w-2 h-2 bg-orange-500 rounded-full"></div>
                        <span class="text-xs text-gray-500 dark:text-gray-400">2 visual differences detected</span>
                    </div>
                </div>
            </div>
            <div class="order-1 lg:order-2 space-y-6">
                <h3 class="text-3xl font-bold text-gray-900 dark:text-white">Visual diffs that know better</h3>
                <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
                    Snapshot tests with a brain. We tell a regression from a redesign so your visual suite stops crying wolf.
                </p>
                <a href="/ai" class="explore-link no-underline inline-flex items-center gap-2 text-orange-500 dark:text-orange-400 font-semibold hover:text-orange-600 dark:hover:text-orange-300 transition-colors">
                    Explore visual testing <span class="arrow">&rarr;</span>
                </a>
            </div>
        </div>

        {/* Feature Panel 3: Natural Language Tests (text left, visual right) */}
        <div class="grid lg:grid-cols-2 gap-16 items-center mb-20">
            <div class="space-y-6">
                <h3 class="text-3xl font-bold text-gray-900 dark:text-white">Write a sentence. Get a test.</h3>
                <p class="text-lg text-gray-500 dark:text-gray-400 leading-relaxed">
                    Describe what the user does. CodeceptJS turns it into runnable steps you can read out loud.
                </p>
                <a href="/ai" class="explore-link no-underline inline-flex items-center gap-2 text-orange-500 dark:text-orange-400 font-semibold hover:text-orange-600 dark:hover:text-orange-300 transition-colors">
                    Explore AI testing <span class="arrow">&rarr;</span>
                </a>
            </div>
            <div class="bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-8 relative overflow-hidden">
                <div class="relative space-y-4">
                    <div class="flex items-center gap-3 mb-6">
                        <div class="w-10 h-10 bg-purple-500/10 dark:bg-purple-500/20 rounded-xl flex items-center justify-center">
                            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-purple-600 dark:text-purple-400"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"></path><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"></path><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path></svg>
                        </div>
                        <span class="text-sm font-semibold text-gray-900 dark:text-white">Natural Language &rarr; Code</span>
                    </div>
                    <div class="p-3 bg-gray-50 dark:bg-gray-900/50 rounded-lg border border-gray-200/50 dark:border-gray-700/50">
                        <p class="text-sm text-gray-600 dark:text-gray-300 italic">"User logs in, adds item to cart, and completes checkout"</p>
                    </div>
                    <div class="flex items-center justify-center">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="text-purple-500"><path d="M12 5v14"></path><path d="m19 12-7 7-7-7"></path></svg>
                    </div>
                    <div class="p-3 bg-gray-900 dark:bg-gray-950 rounded-lg">
                        <code class="text-xs text-green-400 font-mono leading-relaxed">
                            I.login('user');<br/>
                            I.click('Add to Cart');<br/>
                            I.click('Checkout');<br/>
                            I.see('Order confirmed');
                        </code>
                    </div>
                </div>
            </div>
        </div>

        {/* Compact 3-column row for remaining features */}
        <div class="grid md:grid-cols-3 gap-8">
            <div class="mt-0 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 transition-colors duration-200 hover:border-purple-400 dark:hover:border-purple-500">
                <div class="w-10 h-10 bg-purple-500/10 dark:bg-purple-500/20 rounded-xl flex items-center justify-center mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-purple-600 dark:text-purple-400"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"></polygon></svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Edge cases, generated</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Hand it a happy path. It writes the angry, sad, and weird ones too.</p>
            </div>

            <div class="mt-0 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 transition-colors duration-200 hover:border-purple-400 dark:hover:border-purple-500">
                <div class="w-10 h-10 bg-orange-500/10 dark:bg-orange-500/20 rounded-xl flex items-center justify-center mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-orange-600 dark:text-orange-400"><path d="M3 3v18h18"></path><path d="M18 17V9"></path><path d="M13 17V5"></path><path d="M8 17v-3"></path></svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Flake radar</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">See which tests are about to start lying to you, before CI does.</p>
            </div>

            <div class="mt-0 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl p-6 transition-colors duration-200 hover:border-purple-400 dark:hover:border-purple-500">
                <div class="w-10 h-10 bg-purple-500/10 dark:bg-purple-500/20 rounded-xl flex items-center justify-center mb-4">
                    <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="w-5 h-5 text-purple-600 dark:text-purple-400"><path d="m12 3-1.912 5.813a2 2 0 0 1-1.275 1.275L3 12l5.813 1.912a2 2 0 0 1 1.275 1.275L12 21l1.912-5.813a2 2 0 0 1 1.275-1.275L21 12l-5.813-1.912a2 2 0 0 1-1.275-1.275L12 3Z"></path><path d="M5 3v4"></path><path d="M19 17v4"></path><path d="M3 5h4"></path><path d="M17 19h4"></path></svg>
                </div>
                <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-2">Reports that read themselves</h3>
                <p class="text-sm text-gray-500 dark:text-gray-400">Plain-English summaries of what passed, what broke, and why.</p>
            </div>
        </div>
    </div>
</section>
