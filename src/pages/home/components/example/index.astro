---
import IDEPanel from "@/components/ide/IDEPanel";
import type { IDEFile, IDEFolder } from "@/components/ide/IDEPanel";

const files: IDEFile[] = [
  {
    path: "codecept.conf.ts",
    name: "codecept.conf.ts",
    language: "typescript",
    code: `import { setHeadlessWhen } from '@codeceptjs/configure';

setHeadlessWhen(process.env.HEADLESS);

export const config: CodeceptJS.MainConfig = {
  tests: './tests/**/*.test.ts',
  output: './output',
  helpers: {
    Playwright: {
      browser: 'chromium',
      url: process.env.URL || 'http://localhost:3000',
      show: true,
    },
  },
  include: {
    I: './steps_file.ts',
    milestonePage: './pages/Milestone.ts',
    taskPage: './pages/Task.ts',
  },
  plugins: {
    heal: { enabled: true },
    retryFailedStep: { enabled: true },
    auth: {
      enabled: true,
      saveToFile: true,
      users: {
        user: {
          login: (I) => I.login(),
          check: (I) => { I.amOnPage('/'); I.see('Dashboard', '.navbar'); },
        },
      },
    },
  },
  require: ['./support/heal.ts'],
};`,
  },
  {
    path: "tests/milestones.test.ts",
    name: "milestones.test.ts",
    language: "typescript",
    code: `Feature('Milestones');

Before(({ login }) => {
  login();
});

Scenario('Create a milestone @smoke', ({ milestonePage }) => {
  milestonePage.open();
  milestonePage.create({ name: 'Q2 Release', dueDate: '2024-06-30' });
  milestonePage.checkVisible('Q2 Release');
});

Scenario('Milestone tracks task progress', ({ I, milestonePage }) => {
  milestonePage.open();
  milestonePage.select('Q2 Release');
  I.see('0 / 5 tasks', '.progress');
  I.see('0%', '.progress-bar');
});

Scenario('Complete a milestone', ({ I, milestonePage }) => {
  milestonePage.open();
  milestonePage.select('Q2 Release');
  I.click('Mark as Complete');
  I.see('Completed', '.milestone-status');
});`,
  },
  {
    path: "tests/tasks.test.ts",
    name: "tasks.test.ts",
    language: "typescript",
    code: `Feature('Task Management');

Before(({ login }) => {
  login();
});

Scenario('Create and assign a task @smoke', ({ I, taskPage }) => {
  taskPage.openProject('Backend API');
  taskPage.create({
    title: 'Setup CI pipeline',
    assignee: 'Alice',
    milestone: 'Q2 Release',
    priority: 'high',
  });
  I.see('Setup CI pipeline', '.task-board');
  taskPage.checkAssignee('Setup CI pipeline', 'Alice');
});

Scenario('Move task through statuses', ({ I, taskPage }) => {
  taskPage.openProject('Backend API');
  taskPage.setStatus('Setup CI pipeline', 'In Progress');
  I.see('In Progress', '.task-status');
  taskPage.setStatus('Setup CI pipeline', 'Done');
  I.see('1 / 5 tasks', '.milestone-progress');
});`,
  },
  {
    path: "pages/Milestone.ts",
    name: "Milestone.ts",
    language: "typescript",
    code: `const { I } = inject();

class MilestonePage {
  url = '/milestones';
  milestoneList = '.milestone-list';
  nameInput = '#milestone-name';
  dueDateInput = '#due-date';
  submitButton = locate('button').withText('Create Milestone');

  open() {
    I.amOnPage(this.url);
    I.waitForElement(this.milestoneList, 5);
  }

  create({ name, dueDate }: { name: string; dueDate: string }) {
    I.click('New Milestone');
    I.waitForElement(this.nameInput, 5);
    I.fillField(this.nameInput, name);
    I.fillField(this.dueDateInput, dueDate);
    I.click(this.submitButton);
    I.waitForElement(locate('.milestone-item').withText(name), 5);
  }

  select(name: string) {
    I.click(locate('.milestone-item').withText(name));
    I.waitForElement('.milestone-detail', 5);
  }

  checkVisible(name: string) {
    I.waitForElement(locate('.milestone-item').withText(name), 5);
    I.see(name, this.milestoneList);
  }
}

export default MilestonePage`,
  },
  {
    path: "pages/Task.ts",
    name: "Task.ts",
    language: "typescript",
    code: `const { I } = inject();

interface TaskInput {
  title: string;
  assignee?: string;
  milestone?: string;
  priority?: 'low' | 'medium' | 'high';
}

class TaskPage {
  taskBoard = '.task-board';
  createButton = locate('button').withText('Add Task');
  titleInput = '#task-title';

  openProject(name: string) {
    I.amOnPage('/projects');
    I.click(locate('.project-card').withText(name));
    I.waitForElement(this.taskBoard, 10);
  }

  create(task: TaskInput) {
    I.click(this.createButton);
    I.waitForElement(this.titleInput, 5);
    I.fillField(this.titleInput, task.title);
    if (task.assignee) I.selectOption('#task-assignee', task.assignee);
    if (task.milestone) I.selectOption('#task-milestone', task.milestone);
    if (task.priority) I.selectOption('#task-priority', task.priority);
    I.click('Save Task');
    I.waitForElement(locate('.task-item').withText(task.title), 5);
  }

  setStatus(title: string, status: string) {
    I.click(locate('.task-item').withText(title));
    I.waitForElement('.task-detail', 5);
    I.selectOption('#task-status', status);
    I.click('Update');
    I.see(status, '.task-status');
  }

  checkAssignee(title: string, assignee: string) {
    I.see(assignee, locate('.task-item').withText(title));
  }
}

export default TaskPage`,
  },
  {
    path: "support/heal.ts",
    name: "heal.ts",
    language: "typescript",
    code: `import { heal } from 'codeceptjs';

// Tests can randomly fails due to session expiration
// if we see unauthorized message -> relogin and try prev step again
heal.addRecipe('loginOnUnauthorized', {
  priority: 10,
  steps: ['click', 'see', 'amOnPage'],
  prepare: {
    url: ({ I }) => I.grabCurrentUrl(),
    html: ({ I }) => I.grabHTMLFrom('body'),
  },
  fn: async ({ url, error, html, step }) => {
    if (
      !url.includes('/login') &&
      !error.message.toLowerCase().includes('unauthorized') &&
      !html.toLowerCase().includes('Error: Unauthorized')
    ) return;

    return ({ I }) => {
      I.login();
      I[step.name](...step.args);
    };
  },
});

// When UX and HTML changes, flaky locator issues can be picked up by AI
// AI will analyze HTML tree we passed in and will try to fix failing step
// or replace it with a workaround and continue testing
heal.addRecipe('ai', {
  priority: 20,
  steps: ['click', 'fillField', 'selectOption', 'checkOption', 'doubleClick'],
  prepare: {
    html: ({ I }) => I.grabHTMLFrom('body'),
  },
  fn: async (args) => {
    return ai.healFailedStep(args);
  },
});`,
  },
  {
    path: "steps_file.ts",
    name: "steps_file.ts",
    language: "typescript",
    code: `export default function () {
  return actor({
    login() {
      this.amOnPage('/login');
      this.fillField('#email', 'user@pm.app');
      this.fillField('#password', 'secret');
      this.click('Sign In');
      this.waitForElement('.dashboard', 10);
    },
  });
}`,
  },
];

const tree: (IDEFile | IDEFolder)[] = [
  files[0], // codecept.conf.ts
  {
    name: "tests",
    path: "tests",
    children: [files[1], files[2]], // milestones.test.ts, tasks.test.ts
  },
  {
    name: "pages",
    path: "pages",
    children: [files[3], files[4]], // Milestone.ts, Task.ts
  },
  {
    name: "support",
    path: "support",
    children: [files[5]], // heal.ts
  },
  files[6], // steps_file.ts
];
---

<section id="examples" class="!mt-0 py-24 relative transition-colors duration-300">
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 relative">
    <div class="text-center mb-16">
      <h2 class="text-4xl md:text-6xl font-bold mb-6 text-gray-900 dark:text-white">
          Simple, yet <span class="headline-accent">professional</span>.
      </h2>
      <p class="text-xl text-gray-500 dark:text-gray-400 max-w-2xl mx-auto">
          Architecture and test design applied by default
      </p>
    </div>

    <div class="max-w-6xl mx-auto">
      <IDEPanel
        client:load
        files={files}
        tree={tree}
        defaultFile="tests/milestones.test.ts"
      />
    </div>
  </div>

  <style is:global>
    /* Match the hero panel: JetBrains Mono with programming ligatures + the
       same syntax palette (purple keywords, amber strings, pink `I`). */
    .ide-panel pre,
    .ide-panel code {
      font-family: 'JetBrains Mono', ui-monospace, SFMono-Regular, monospace !important;
      font-feature-settings: 'calt' 1, 'liga' 1, 'ss01' 1, 'ss02' 1, 'ss03' 1, 'ss19' 1, 'zero' 1;
      font-variant-ligatures: contextual common-ligatures;
      font-size: 13.5px !important;
      line-height: 1.7;
    }

  </style>
</section>
